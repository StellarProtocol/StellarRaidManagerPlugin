<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <NoWarn>CS8632;CS8765</NoWarn>
    <RootNamespace>Stellar.RaidManager</RootNamespace>
    <AssemblyName>Stellar.RaidManager</AssemblyName>
    <Version>1.0.0</Version>
    <Deterministic>true</Deterministic>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources/raid-manager-icon.png" LogicalName="Stellar.RaidManager.raid-manager-icon.png" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Stellar.Abstractions" Version="1.1.1" />
    <PackageReference Include="Stellar.PluginContracts" Version="1.1.1" />
    <PackageReference Include="Stellar.Plugin.InteropRefs" Version="1.1.1" />
  </ItemGroup>
  <ItemGroup>
    <Compile Remove="tests/**/*.cs" />
  </ItemGroup>
</Project>
